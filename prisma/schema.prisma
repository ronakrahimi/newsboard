generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Feed {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  name      String
  category  String   @default("General")
  createdAt DateTime @default(now())
}
